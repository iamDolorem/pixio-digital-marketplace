---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Восстановление пароля">
  <main class="min-h-screen bg-[#e6edf4] text-slate-900">
    <section class="mx-auto max-w-6xl px-5 py-8">
      <div class="mx-auto max-w-[520px] rounded-[24px] border border-slate-300/80 bg-[rgba(255,255,255,0.55)] p-8 backdrop-blur-sm">
        <h1 class="mb-4 text-3xl font-semibold text-slate-900">Восстановление пароля</h1>

        <p class="mb-6 text-sm leading-6 text-slate-600">
          Введите электронную почту, привязанную к аккаунту. Если такой аккаунт существует,
          система сформирует ссылку для сброса пароля.
        </p>

        <form id="forgot-password-form" class="space-y-5">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700" for="email-field">
              Электронная почта
            </label>
            <input
              id="email-field"
              type="email"
              placeholder="Введите email"
              autocomplete="email"
              class="w-full rounded-[16px] border border-slate-300/80 bg-[rgba(255,255,255,0.72)] px-4 py-3 text-[14px] text-slate-900 outline-none focus:border-slate-500"
            />
          </div>

          <div id="message-box" class="hidden rounded-[16px] px-4 py-3 text-sm"></div>

          <div id="demo-link-box" class="hidden rounded-[16px] border border-slate-300/80 bg-[rgba(255,255,255,0.55)] px-4 py-4">
            <p class="mb-2 text-sm font-medium text-slate-900">
              Демонстрационная ссылка сброса
            </p>
            <p class="mb-3 text-xs leading-5 text-slate-600">
              В промышленной версии эта ссылка отправляется пользователю на email.
              Для дипломной демонстрации она отображается на странице.
            </p>
            <a
              id="reset-link"
              href="#"
              class="break-all text-sm font-medium text-[#2d4157] hover:underline"
            ></a>
          </div>

          <div class="space-y-3 pt-1">
            <button
              id="submit-button"
              type="submit"
              class="w-full rounded-[16px] bg-[#2d4157] px-5 py-3 text-sm font-medium text-white transition hover:bg-[#24364a]"
            >
              Отправить инструкции
            </button>

            <a
              href="/login"
              class="block w-full rounded-[16px] bg-[rgba(45,65,87,0.08)] px-5 py-3 text-center text-sm text-slate-900 transition hover:bg-[rgba(45,65,87,0.14)]"
            >
              Назад
            </a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const API_URL = 'http://192.168.1.87:5555/api/auth/forgot-password';

    const form = document.getElementById('forgot-password-form');
    const emailField = document.getElementById('email-field');
    const submitButton = document.getElementById('submit-button');
    const messageBox = document.getElementById('message-box');
    const demoLinkBox = document.getElementById('demo-link-box');
    const resetLink = document.getElementById('reset-link');

    const showMessage = (text, type = 'info') => {
      if (!messageBox) return;

      messageBox.textContent = text;
      messageBox.classList.remove(
        'hidden',
        'bg-red-100',
        'text-red-700',
        'bg-green-100',
        'text-green-700',
        'bg-slate-100',
        'text-slate-700'
      );

      if (type === 'error') {
        messageBox.classList.add('bg-red-100', 'text-red-700');
      } else if (type === 'success') {
        messageBox.classList.add('bg-green-100', 'text-green-700');
      } else {
        messageBox.classList.add('bg-slate-100', 'text-slate-700');
      }
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!(emailField instanceof HTMLInputElement)) return;

      const email = emailField.value.trim();

      if (!email) {
        showMessage('Введите email.', 'error');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Отправка...';
      }

      demoLinkBox?.classList.add('hidden');

      try {
        const response = await fetch(API_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ email })
        });

        const data = await response.json();

        if (!response.ok || !data.success) {
          showMessage(data.message || 'Не удалось сформировать ссылку восстановления.', 'error');
          return;
        }

        showMessage(
          'Если аккаунт существует, инструкции для сброса пароля сформированы.',
          'success'
        );

        if (data.resetLink && resetLink && demoLinkBox) {
          resetLink.textContent = data.resetLink;
          resetLink.setAttribute('href', data.resetLink);
          demoLinkBox.classList.remove('hidden');
        }
      } catch (error) {
        showMessage('Ошибка соединения с сервером.', 'error');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = 'Отправить инструкции';
        }
      }
    });
  </script>
</Layout>