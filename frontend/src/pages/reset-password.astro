---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Сброс пароля">
  <main class="min-h-screen bg-[#e6edf4] text-slate-900">
    <section class="mx-auto max-w-6xl px-5 py-8">
      <div class="mx-auto max-w-[520px] rounded-[24px] border border-slate-300/80 bg-[rgba(255,255,255,0.55)] p-8 backdrop-blur-sm">
        <h1 class="mb-4 text-3xl font-semibold text-slate-900">Сброс пароля</h1>

        <p class="mb-6 text-sm leading-6 text-slate-600">
          Введите новый пароль. Ссылка восстановления одноразовая и действует ограниченное время.
        </p>

        <div id="token-error" class="hidden rounded-[16px] bg-red-100 px-4 py-3 text-sm text-red-700">
          Ссылка восстановления некорректна или отсутствует.
        </div>

        <form id="reset-password-form" class="space-y-5">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700" for="password-field">
              Новый пароль
            </label>
            <input
              id="password-field"
              type="password"
              placeholder="Введите новый пароль"
              autocomplete="new-password"
              class="w-full rounded-[16px] border border-slate-300/80 bg-[rgba(255,255,255,0.72)] px-4 py-3 text-[14px] text-slate-900 outline-none focus:border-slate-500"
            />
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700" for="repeat-password-field">
              Повторите пароль
            </label>
            <input
              id="repeat-password-field"
              type="password"
              placeholder="Повторите новый пароль"
              autocomplete="new-password"
              class="w-full rounded-[16px] border border-slate-300/80 bg-[rgba(255,255,255,0.72)] px-4 py-3 text-[14px] text-slate-900 outline-none focus:border-slate-500"
            />
          </div>

          <div id="message-box" class="hidden rounded-[16px] px-4 py-3 text-sm"></div>

          <div class="space-y-3 pt-1">
            <button
              id="submit-button"
              type="submit"
              class="w-full rounded-[16px] bg-[#2d4157] px-5 py-3 text-sm font-medium text-white transition hover:bg-[#24364a]"
            >
              Сохранить новый пароль
            </button>

            <a
              href="/login"
              class="block w-full rounded-[16px] bg-[rgba(45,65,87,0.08)] px-5 py-3 text-center text-sm text-slate-900 transition hover:bg-[rgba(45,65,87,0.14)]"
            >
              К странице входа
            </a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const API_URL = 'http://192.168.1.87:5555/api/auth/reset-password';

    const params = new URLSearchParams(window.location.search);
    const token = params.get('token') || '';

    const form = document.getElementById('reset-password-form');
    const tokenError = document.getElementById('token-error');
    const passwordField = document.getElementById('password-field');
    const repeatPasswordField = document.getElementById('repeat-password-field');
    const submitButton = document.getElementById('submit-button');
    const messageBox = document.getElementById('message-box');

    const showMessage = (text, type = 'info') => {
      if (!messageBox) return;

      messageBox.textContent = text;
      messageBox.classList.remove(
        'hidden',
        'bg-red-100',
        'text-red-700',
        'bg-green-100',
        'text-green-700',
        'bg-slate-100',
        'text-slate-700'
      );

      if (type === 'error') {
        messageBox.classList.add('bg-red-100', 'text-red-700');
      } else if (type === 'success') {
        messageBox.classList.add('bg-green-100', 'text-green-700');
      } else {
        messageBox.classList.add('bg-slate-100', 'text-slate-700');
      }
    };

    if (!token) {
      tokenError?.classList.remove('hidden');

      if (form instanceof HTMLFormElement) {
        form.classList.add('hidden');
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (
        !(passwordField instanceof HTMLInputElement) ||
        !(repeatPasswordField instanceof HTMLInputElement)
      ) {
        return;
      }

      const password = passwordField.value.trim();
      const repeatPassword = repeatPasswordField.value.trim();

      if (!password || !repeatPassword) {
        showMessage('Заполните оба поля пароля.', 'error');
        return;
      }

      if (password.length < 6) {
        showMessage('Пароль должен содержать минимум 6 символов.', 'error');
        return;
      }

      if (password !== repeatPassword) {
        showMessage('Пароли не совпадают.', 'error');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Сохранение...';
      }

      try {
        const response = await fetch(API_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            token,
            password
          })
        });

        const data = await response.json();

        if (!response.ok || !data.success) {
          showMessage(data.message || 'Не удалось изменить пароль.', 'error');
          return;
        }

        showMessage('Пароль успешно изменён. Теперь можно войти с новым паролем.', 'success');

        passwordField.value = '';
        repeatPasswordField.value = '';

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = 'Пароль изменён';
        }
      } catch (error) {
        showMessage('Ошибка соединения с сервером.', 'error');
      } finally {
        if (
          submitButton instanceof HTMLButtonElement &&
          submitButton.textContent !== 'Пароль изменён'
        ) {
          submitButton.disabled = false;
          submitButton.textContent = 'Сохранить новый пароль';
        }
      }
    });
  </script>
</Layout>